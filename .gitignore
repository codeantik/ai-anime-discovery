# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# frontend dependencies & build output
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.pnp
frontend/.pnp.*

# next.js generated (root-level, stale from scaffold)
.next/
next-env.d.ts

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# Python / uv
backend/.venv/
backend/**/__pycache__/
backend/**/*.pyc

# Data (built artifacts) — anime.faiss + anime_meta.json are committed so
# the index ships with the repo (offline-build architecture, free CI eval)
data/*.db
data/cache/
