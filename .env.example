# MongoDB Atlas — https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MyAnimeList OAuth — https://myanimelist.net/apiconfig
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=

# Active provider: openai | gemini | groq | ollama
LLM_PROVIDER=openai

# Backend URL (used by Next.js proxy rewrite)
BACKEND_URL=http://localhost:8001

# MAL OAuth callback — must match what you registered in https://myanimelist.net/apiconfig
MAL_REDIRECT_URI=http://localhost:8001/auth/mal/callback
# Frontend URL — backend redirects here after OAuth callback
FRONTEND_URL=http://localhost:3000

# Public backend URL exposed to the browser (for the "Connect MAL" login link)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=

# LangSmith observability — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-anime-discovery
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
