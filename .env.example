# MongoDB Atlas — https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AniList OAuth — https://anilist.co/settings/developer
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# Active provider: openai | gemini | groq | ollama
LLM_PROVIDER=openai

# Backend deploy environment: development | production
# Controls auth cookie flags. The frontend proxies all backend calls through
# its own origin (see frontend/next.config.ts rewrites()), so the cookie is
# always first-party — SameSite=Lax; Secure in production.
ENVIRONMENT=development

# AniList OAuth callback — must point at the FRONTEND's proxy path (not the
# Render URL directly), so the OAuth redirect lands same-origin and the
# cookie set during /auth/anilist/callback is first-party in the browser.
# Must also match what you registered in https://anilist.co/settings/developer
# Local: http://localhost:3000/api/backend/auth/anilist/callback
# Prod:  https://<your-vercel-app>.vercel.app/api/backend/auth/anilist/callback
ANILIST_REDIRECT_URI=http://localhost:3000/api/backend/auth/anilist/callback
# Frontend URL — backend redirects here after OAuth callback, and is the only
# origin allowed by CORS. Local: http://localhost:3000. Prod: https://<your-vercel-app>.vercel.app
FRONTEND_URL=http://localhost:3000

# MAL OAuth — https://myanimelist.net/apps.php (register an app first)
# Gotcha: MAL only supports PKCE code_challenge_method=plain (code_challenge ==
# code_verifier) — most OAuth libraries default to S256, override explicitly.
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
# Same same-origin-proxy reasoning as ANILIST_REDIRECT_URI above.
# Local: http://localhost:3000/api/backend/auth/mal/callback
# Prod:  https://<your-vercel-app>.vercel.app/api/backend/auth/mal/callback
MAL_REDIRECT_URI=http://localhost:3000/api/backend/auth/mal/callback

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an "OAuth client ID" (type: Web application). Identity provider only —
# used for app sign-in, decoupled from AniList/MAL data links.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same same-origin-proxy reasoning as ANILIST_REDIRECT_URI above.
# Register this exact URI as an "Authorized redirect URI" in Google Cloud Console.
# Local: http://localhost:3000/api/backend/auth/google/callback
# Prod:  https://<your-vercel-app>.vercel.app/api/backend/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/backend/auth/google/callback

# Secret used to sign our own app session JWT (issued after Google sign-in).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Backend URL used server-side by the frontend's Next.js rewrite proxy
# (frontend/next.config.ts) — never exposed to the browser, no NEXT_PUBLIC_ prefix.
# Local: http://localhost:8001. Prod: https://<your-render-app>.onrender.com
BACKEND_URL=http://localhost:8001

# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=

# LangSmith observability — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-anime-discovery
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
