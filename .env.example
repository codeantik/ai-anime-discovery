# MongoDB Atlas — https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AniList OAuth — https://anilist.co/settings/developer
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# Active provider: openai | gemini | groq | ollama
LLM_PROVIDER=openai

# Backend deploy environment: development | production
# Controls auth cookie flags — production sends SameSite=None; Secure so the
# cookie survives cross-site fetches between the Vercel frontend and Render backend.
ENVIRONMENT=development

# AniList OAuth callback — must match what you registered in https://anilist.co/settings/developer
# Local: http://localhost:8001/auth/anilist/callback
# Prod:  https://<your-render-app>.onrender.com/auth/anilist/callback
ANILIST_REDIRECT_URI=http://localhost:8001/auth/anilist/callback
# Frontend URL — backend redirects here after OAuth callback, and is the only
# origin allowed by CORS. Local: http://localhost:3000. Prod: https://<your-vercel-app>.vercel.app
FRONTEND_URL=http://localhost:3000

# Public backend URL exposed to the browser — the frontend calls this directly
# (not proxied) so auth cookies set by the backend are sent on every request.
# Local: http://localhost:8001. Prod: https://<your-render-app>.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=

# LangSmith observability — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-anime-discovery
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
