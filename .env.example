# MongoDB Atlas — https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AniList OAuth — https://anilist.co/settings/developer
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# Active provider: openai | gemini | groq | ollama
LLM_PROVIDER=openai

# Backend URL (used by Next.js proxy rewrite)
BACKEND_URL=http://localhost:8001

# AniList OAuth callback — must match what you registered in https://anilist.co/settings/developer
ANILIST_REDIRECT_URI=http://localhost:8001/auth/anilist/callback
# Frontend URL — backend redirects here after OAuth callback
FRONTEND_URL=http://localhost:3000

# Public backend URL exposed to the browser (for the "Connect AniList" login link)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=

# LangSmith observability — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-anime-discovery
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
